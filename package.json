{
  "name": "@w3cj/ruta",
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@10.33.0",
  "description": "A tiny type-safe client-side router for hono/jsx",
  "author": "",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/w3cj/ruta"
  },
  "keywords": [
    "hono",
    "router",
    "jsx",
    "client-side",
    "react-router"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "vite build",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "check:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm no-resolution",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "size-limit": [
    {
      "name": "full (import *)",
      "path": "dist/index.js",
      "import": "*",
      "limit": "3 kB"
    }
  ],
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@size-limit/esbuild": "^12.0.1",
    "@size-limit/esbuild-why": "^12.0.0",
    "@size-limit/file": "^12.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "happy-dom": "^20.8.9",
    "hono": "^4.7.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  }
}
